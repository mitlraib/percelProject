{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types"],

    "rootDir": ".",
    "outDir": "./dist"
  },
  "include": ["**/*.ts"]
}